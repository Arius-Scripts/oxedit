{
  "name": "oxEdit — ox_inventory editor",
  "short_name": "oxEdit",
  "description": "Free in-browser editor for ox_inventory items, weapons, shops, crafting and stashes.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0b0f10",
